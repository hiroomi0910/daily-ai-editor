SIZU_OUTPUT_MODE=local

# Obsidian Vault への保存先パス（SIZU_OUTPUT_MODE=obsidian の場合に必須）
# 環境に合わせて以下のいずれかを設定してください。
#
# Mac (iCloud Drive の場合):
#   SIZU_OBSIDIAN_VAULT_PATH=/Users/yourname/Library/Mobile Documents/iCloud~md~obsidian/Documents/obsidian_vault
# Mac (Synology Drive の場合):
#   SIZU_OBSIDIAN_VAULT_PATH=/Users/yourname/Library/CloudStorage/SynologyDrive-Obsidian/obsidian_vault
# Mac (ローカル):
#   SIZU_OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/obsidian_vault
# Windows (Synology Drive の場合):
#   SIZU_OBSIDIAN_VAULT_PATH=C:\Users\yourname\SynologyDrive\obsidian_vault
# Windows (ローカル):
#   SIZU_OBSIDIAN_VAULT_PATH=C:\Users\yourname\Documents\obsidian_vault
SIZU_OBSIDIAN_VAULT_PATH=

# Obsidian Vault 内のプロジェクトディレクトリ（Vault ルートからの相対パス）
SIZU_PROJECT_WORKSPACE=03_Projects/SIZU_PROJECT

SIZU_BLUESKY_ACTOR=
SIZU_BLUESKY_LIMIT=25
SIZU_BLUESKY_FILTER=posts_no_replies

OPENAI_API_KEY=
SIZU_OPENAI_MODEL=gpt-4o-mini

SIZU_AI_PROVIDER=openai

GEMINI_API_KEY=
# 無料ティアで安定して動作する軽量・高速モデル
SIZU_GEMINI_MODEL=gemini-2.5-flash
# 高品質な上位モデル（※無料枠アカウントでは利用制限により 429 エラーになる場合があります）
# SIZU_GEMINI_MODEL=gemini-2.5-pro

SIZU_GITHUB_USERNAME=
GITHUB_TOKEN=

SIZU_TWITTER_USERNAME=
SIZU_RSS_FEEDS=
SIZU_THREADS_USERNAME=
SIZU_INSTAGRAM_USERNAME=
SIZU_FACEBOOK_USERNAME=
# しずかなインターネットのユーザー名（自動下書き投稿時のプレビューURL解決に使用。例: sizu.me/user なら user）
SIZU_USERNAME=
